generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MoodEntry {
  id        String   @id @default(cuid())
  mood      Int      // 1-5 scale
  emotion   String   // emotion label
  note      String?  // optional note
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())
}
